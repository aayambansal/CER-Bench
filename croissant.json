  "ml:recordSet": [
    {
      "@type": "ml:RecordSet",
      "name": "tasks",
      "ml:field": [
        {
          "@type": "ml:Field",
          "name": "task_id",
          "ml:dataType": "sc:Text",
          "description": "Unique task identifier",
          "ml:source": {
            "@type": "ml:DataSource",
            "distribution": {"@id": "v1-test-file"},
            "ml:extract": {"ml:column": "task_id"}
          }
        },
        {
          "@type": "ml:Field",
          "name": "task_family",
          "ml:dataType": "sc:Text",
          "description": "One of: constraint, comparative, contradiction, abstention, multihop, temporal, aggregation, negative",
          "ml:source": {
            "@type": "ml:DataSource",
            "distribution": {"@id": "v1-test-file"},
            "ml:extract": {"ml:column": "task_family"}
          }
        },
        {
          "@type": "ml:Field",
          "name": "question",
          "ml:dataType": "sc:Text",
          "description": "Natural-language retrieval query",
          "ml:source": {
            "@type": "ml:DataSource",
            "distribution": {"@id": "v1-test-file"},
            "ml:extract": {"ml:column": "question"}
          }
        },
        {
          "@type": "ml:Field",
          "name": "difficulty",
          "ml:dataType": "sc:Text",
          "description": "easy, medium, or hard",
          "ml:source": {
            "@type": "ml:DataSource",
            "distribution": {"@id": "v1-test-file"},
            "ml:extract": {"ml:column": "difficulty"}
          }
        },
        {
