            "ml:extract": {"ml:column": "supporting_doc_ids"}
          }
        },
        {
          "@type": "ml:Field",
          "name": "hard_negative_doc_ids",
          "ml:dataType": "sc:Text",
          "description": "JSON array of hard negative document IDs",
          "ml:source": {
            "@type": "ml:DataSource",
            "distribution": {"@id": "v1-test-file"},
            "ml:extract": {"ml:column": "hard_negative_doc_ids"}
